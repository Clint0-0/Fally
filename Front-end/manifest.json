{
  "manifest_version": 3,
  "name": "ToxiGuard - Content Moderator",
  "version": "1.0.0",
  "description": "Scans web pages for slurs, hate speech, and toxic language.",

  "permissions": ["activeTab", "storage"],

  "host_permissions": [
    "http://localhost:5000/*"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}